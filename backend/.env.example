# Backend production environment template
# Copy to backend/.env and fill with real values.

# Core Django
SECRET_KEY=replace-with-a-long-random-secret
DEBUG=False
ALLOWED_HOSTS=your-api-domain.com,localhost,127.0.0.1

# CORS
CORS_ALLOW_ALL_ORIGINS=False
CORS_ALLOWED_ORIGINS=https://your-frontend-domain.com,http://localhost:5173

# Database (preferred)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/sskatt_wts_db

# Database (fallback style; use only if DATABASE_URL is not set)
DATABASE_NAME=sskatt_wts_db
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres
DATABASE_HOST=localhost
DATABASE_PORT=5432

# Realtime (required for multi-instance production)
REDIS_URL=redis://localhost:6379/0

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
